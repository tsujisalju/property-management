# Copy this file to .env and fill in your own values.
# NEVER commit .env to git.

# AWS credentials (use your personal test account during development)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1

# S3 bucket for file uploads (create one per team member in your test account)
AWS_S3_BUCKET=

# SES sender address (must be verified in your AWS account)
AWS_SES_SENDER=noreply@yourdomain.com

# Cognito (can leave blank during early dev — auth is optional initially)
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
